# Copy this file to .env and fill in real values. NEVER commit the real .env.

# GitHub Personal Access Token - free, generate at:
# https://github.com/settings/tokens/new?scopes=public_repo
GITHUB_PAT=ghp_your_token_here

# Groq API key - free tier at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

PORT=3000
